    3: { label: 'Partly cloudy', emoji: '⛅', type: 'cloudy' },
    45: { label: 'Foggy', emoji: '🌫️', type: 'cloudy' },
    51: { label: 'Rainy', emoji: '🌧️', type: 'rain' },
    67: { label: 'Rainy', emoji: '🌧️', type: 'rain' },
    71: { label: 'Snowy', emoji: '❄️', type: 'snow' },
    77: { label: 'Snowy', emoji: '❄️', type: 'snow' },
    80: { label: 'Stormy', emoji: '⛈️', type: 'storm' },
