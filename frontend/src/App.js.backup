    } catch (err) {
      setAuthError(err.message);
    }
  };

  const handleGuestLogin = () => {
    const sessionData = {
      userId: 'guest_' + Date.now(),
      token: 'guest_token',
      name: 'Guest',
      isGuest: true
    };
    localStorage.setItem('travelUser', JSON.stringify(sessionData));
    setUser(sessionData);
    setCurrentPage('chat');
    setChatHistory([]);
    setCurrentQuestion(0);

    setTimeout(() => {
      getNextQuestion(0);
