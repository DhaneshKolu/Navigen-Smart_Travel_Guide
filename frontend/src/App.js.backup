      localStorage.setItem('travelUser', JSON.stringify(sessionData));
      setUser(sessionData);
      setCurrentPage('chat');
      setChatHistory([]);
      setCurrentQuestion(0);

      setTimeout(() => {
        getNextQuestion(0);
