  };

  // ========== FETCH ITINERARY ==========
  const fetchItinerary = async () => {
    setLoading(true);
    setError(null);

    const loadingMessages = [
      'Talking to your AI travel agents...',
      'Scouting the best spots in ' + chatData.destination + '...',
      'Checking local weather and conditions...',
