    if (!usd) return 0;
    return Math.round(usd * exchangeRates[currency]);
  };

  // ========== SEARCH PLACES ==========
  const searchPlaces = async (query) => {
    if (query.length < 3) {
      setAutocompleteResults([]);
      return;
    }
    try {
      const res = await fetch(
        `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=5&addressdetails=1`,
        { headers: { 'Accept-Language': 'en' } }
      );
      const data = await res.json();
      const results = data.map(p => ({
        label: p.display_name.split(',').slice(0, 3).join(','),
        lat: parseFloat(p.lat),
        lng: parseFloat(p.lon),
        city: p.address?.city || p.address?.town || p.address?.village || query,
        country: p.address?.country
      }));
      setAutocompleteResults(results);
    } catch (err) {
      console.error('Autocomplete error:', err);
    }
  };

  // ========== DEBOUNCED AUTOCOMPLETE ==========
  const handleAutocompleteChange = (e, type) => {
    const value = e.target.value;
    if (type === 'origin') {
      setChatData(prev => ({ ...prev, origin: value }));
    } else {
      setChatData(prev => ({ ...prev, destination: value }));
    }
    setAutocompleteType(type);

    clearTimeout(autocompleteTimeoutRef.current);
    autocompleteTimeoutRef.current = setTimeout(() => {
      searchPlaces(value);
    }, 350);
  };

  // ========== SELECT PLACE ==========
  const selectPlace = (place, type) => {
    if (type === 'origin') {
      setChatData(prev => ({
        ...prev,
        origin: place.city,
        originLat: place.lat,
        originLng: place.lng
      }));
    } else {
      setChatData(prev => ({
        ...prev,
        destination: place.city,
        destLat: place.lat,
        destLng: place.lng
      }));
    }
    setAutocompleteResults([]);
  };

  // ========== HANDLE CHAT ANSWER ==========
  const handleChatAnswer = (value) => {
    const questions = [
      'origin',
      'destination',
      'days',
      'vibes',
      'group_type',
      'budget_level',
      'special_requests'
    ];

    if (currentQuestion < questions.length) {
      const field = questions[currentQuestion];

      if (currentQuestion === 2) {
        setChatData(prev => ({ ...prev, days: parseInt(value) || null }));
      } else if (currentQuestion === 3) {
        setChatData(prev => ({ ...prev, vibes: Array.isArray(value) ? value : [] }));
      } else {
        setChatData(prev => ({ ...prev, [field]: value }));
      }

      setChatHistory(prev => [...prev, { role: 'user', text: value }]);
      setCurrentQuestion(prev => prev + 1);

      setTimeout(() => {
        if (currentQuestion + 1 < questions.length) {
          getNextQuestion(currentQuestion + 1);
        }
