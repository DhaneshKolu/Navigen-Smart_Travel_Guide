        type: 'location'
      },
      {
        role: 'bot',
        text: 'Amazing! And where\'s the dream destination?',
        type: 'location'
      },
      {
        role: 'bot',
        text: 'How many days are you thinking?',
        type: 'days'
      },
      {
        role: 'bot',
        text: 'What\'s your travel vibe?',
        type: 'vibes'
      },
      {
        role: 'bot',
        text: 'Who\'s joining you?',
        type: 'group'
      },
      {
        role: 'bot',
        text: 'What\'s your daily budget per person?',
        type: 'budget'
      },
